{
  "name": "winyolo",
  "version": "0.3.0",
  "description": "Windows-native Codex launcher and localhost conversation companion.",
  "type": "module",
  "bin": {
    "winyolo": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun --watch src/cli.ts serve",
    "start": "bun run src/cli.ts serve",
    "doctor": "bun run src/cli.ts doctor",
    "demo": "bun run src/cli.ts demo",
    "demo:reset": "powershell -NoProfile -ExecutionPolicy Bypass -File demo/BrokenBuild/reset.ps1",
    "demo:verify": "powershell -NoProfile -ExecutionPolicy Bypass -File demo/BrokenBuild/verify.ps1",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:unit": "bun test test",
    "test:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-windows.ps1",
    "deploy:windows": "bun run scripts/deploy-windows.ts",
    "validate:plugin": "bun run scripts/validate-plugin.ts",
    "check": "bun run typecheck && bun run test && bun run validate:plugin && bun run scripts/source-scan.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "license": "MIT"
}
