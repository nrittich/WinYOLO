# Required for the primary OpenAI Responses API provider.
OPENAI_API_KEY=

# Optional runtime configuration.
WINYOLO_MODEL=gpt-5.6
WINYOLO_PROVIDER=openai
WINYOLO_PORT=4747
WINYOLO_HOST=127.0.0.1
WINYOLO_MAX_STEPS=20
WINYOLO_COMMAND_TIMEOUT_MS=120000
WINYOLO_MAX_OUTPUT_BYTES=200000
# WINYOLO_DATA_DIR=C:\Users\you\AppData\Local\WinYOLO
